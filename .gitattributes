# .gitattributes — KETIV-Technologies-Inc/.github
#
# Pins line-ending behavior per file type so the bytes in the repo are
# the same regardless of who clones it on Windows / macOS / Linux.
# Without this file, behavior depends on each contributor's local
# core.autocrlf setting, which produces noisy diffs and platform-specific bugs.

# Default — Git auto-detects text vs. binary; text files normalize to LF in the repo.
* text=auto eol=lf

# ----- Forced LF -----
# These either run on Linux runners, are parsed by tools that dislike CRLF,
# or have no reason to differ across platforms.

# Documentation
*.md       text eol=lf
*.txt      text eol=lf

# Config / data
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.toml     text eol=lf
*.xml      text eol=lf

# Shell / Unix tooling
*.sh       text eol=lf
*.bash     text eol=lf
Dockerfile text eol=lf
Makefile   text eol=lf

# Code (most everything we'll ever check in here)
*.cs       text eol=lf diff=csharp
*.csproj   text eol=lf
*.sln      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.py       text eol=lf diff=python

# ----- Forced CRLF -----
# Windows-native scripting. PowerShell *can* tolerate LF, but the Windows
# convention is CRLF and some tooling still trips over LF.

*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf
*.psm1     text eol=crlf

# ----- Binaries -----
# Marked explicit so Git doesn't try to diff or convert them.

*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.svg      binary
*.pdf      binary
*.zip      binary
*.gz       binary
*.7z       binary
*.dll      binary
*.exe      binary
*.so       binary
*.dylib    binary

# ----- GitHub-specific -----
# Mark generated/lock files to keep diffs tidy on the GitHub UI.

*.lock              linguist-generated=true
package-lock.json   linguist-generated=true
yarn.lock           linguist-generated=true
pnpm-lock.yaml      linguist-generated=true

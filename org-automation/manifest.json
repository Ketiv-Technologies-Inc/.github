{
  "schemaVersion": "1.0",
  "defaults": {
    "applyTo": "*",
    "skipForks": true,
    "skipArchived": true
  },
  "tools": [
    {
      "id": "trufflehog",
      "kind": "workflowFile",
      "enabled": true,
      "required": true,
      "source": {
        "type": "githubRepo",
        "repo": "Ketiv-Technologies-Inc/.github",
        "path": "workflow-templates/trufflehog.yml",
        "ref": "main"
      },
      "target": ".github/workflows/trufflehog.yml",
      "appliesTo": "*"
    },
    {
      "id": "merge-button-defaults",
      "kind": "repoSetting",
      "enabled": true,
      "required": true,
      "settings": {
        "allow_squash_merge": true,
        "allow_merge_commit": false,
        "allow_rebase_merge": false,
        "delete_branch_on_merge": true
      },
      "appliesTo": "*"
    }
  ]
}
